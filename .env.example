# --- Base ---
AUTH_SECRET="gere-com-openssl-rand-base64-32"

# Desenvolvimento local (Postgres via Docker — ver docker-compose.yml):
#   docker compose up -d
#   npm run db:migrate
#   npm run db:seed
DATABASE_URL="postgresql://mov:mov@localhost:5432/mov?schema=public"

# Staging / produção: Postgres gerido (Neon, Supabase, Vercel Postgres, etc.)
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# URL pública HTTPS — MESMA origem para app, Auth e links (sem barra final).
# Em dev local podes omitir AUTH_URL e NEXTAUTH_URL para o host vir do pedido.
# NEXT_PUBLIC_APP_URL="https://mov-staging.vercel.app"
# AUTH_URL="https://mov-staging.vercel.app"
# NEXTAUTH_URL="https://mov-staging.vercel.app"

NEXT_PUBLIC_APP_URL="http://127.0.0.1:3456"

# Opcional: envio de e-mail (recuperação de senha)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="MOV <noreply@example.com>"

# Seed: conta admin (npm run db:seed)
# ADMIN_SEED_EMAIL="admin@example.com"
# ADMIN_SEED_PASSWORD="..."
