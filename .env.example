# --- Produção (hospedagem com domínio) ---
# Obrigatórios para o site, sessões e ligação de e-mail: configure no painel do fornecedor (Vercel, etc.).
# AUTH_SECRET — o mesmo em todos os deploys; gere com: openssl rand -base64 32
# NEXT_PUBLIC_APP_URL e APP_URL — o URL canónico, ex.: "https://se-mov.com" (sem barra final; iguais entre si)
# DATABASE_URL — dev/local usa SQLite no `prisma/schema.prisma`.
# Produção usa Postgres via schema derivado (`npm run db:generate:prod` e `npm run db:migrate:prod`),
# sem quebrar o fluxo local.
# E-mail: RESEND_API_KEY, ou Mailtrap, ou SMTP_* (ver comentários abaixo) — e MAIL_FROM/EMAIL_FROM com o domínio
#   verificado (SPF/DKIM no DNS).
# Google OAuth: na Google Cloud Console, credenciais Web com redirect URI
#   "https://se-mov.com/api/auth/callback/google" (canónico sem www)
# Na Vercel, a build usa `npm run db:generate:prod` (ver `vercel.json`) para gerar client com schema Postgres.
#
# --- Base ---
AUTH_SECRET="gere-com-openssl-rand-base64-32"

# OAuth Google (opcional — login "Continuar com Google" na rota /entrar)
# Criar credenciais OAuth 2.0 (tipo Web) na Google Cloud Console; URIs de redirecionamento:
#   http://localhost:3456/api/auth/callback/google
# AUTH_GOOGLE_ID="....apps.googleusercontent.com"
# AUTH_GOOGLE_SECRET="GOCSPX-..."

# Desenvolvimento local (recomendado — sem Docker): SQLite num ficheiro.
# Após clonar: npm run db:push && npm run db:seed
DATABASE_URL="file:./dev.db"

# Alternativa local: Postgres via Docker (docker-compose.yml) — para alinhar com produção,
# use scripts `db:generate:prod`/`db:migrate:prod` e DATABASE_URL Postgres.
# DATABASE_URL="postgresql://mov:mov@localhost:5432/mov?schema=public"

# Staging / produção: Postgres gerido (recomendado)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# --- Asaas (cobrança Pix / Speed Dating em /app/ex/datas/.../pagamento) ---
# Chave: Integrations > API Key (sandbox: https://sandbox.asaas.com — produção: asaas.com).
# Cabeçalho enviado pelo código: access_token = este valor. Use chave de sandbox no dev, produção no deploy.
# Opcional: URL base; omissão = https://api-sandbox.asaas.com. Produção: https://api.asaas.com
# ASAAS_API_KEY="$aact_..." 
# ASAAS_API_BASE_URL="https://api-sandbox.asaas.com"
#
# Webhooks: deixar pendente — hoje a confirmação usa polling a partir do cliente; pode adicionar POST
#   /api/webhooks/asaas (validação por token) para actualizar a BD sem o browser.
#
# URL pública (sem barra final). Em dev use localhost de forma consistente (3456 = npm run dev).
# APP_URL: links gerados no servidor (ex.: e-mail de recuperação de senha)
# NEXT_PUBLIC_APP_URL: metadata Auth.js / browser — deve coincidir com o host onde abres a app
APP_URL="http://localhost:3456"
NEXT_PUBLIC_APP_URL="http://localhost:3456"
#
# Staging / produção (domínio oficial canónico) — manter EXATAmente o mesmo esquema e host em APP_URL e NEXT_PUBLIC_APP_URL:
# APP_URL="https://se-mov.com"
# NEXT_PUBLIC_APP_URL="https://se-mov.com"

# Identidade de e-mail em UI (site footer, texto de e-mails transaccionais). Omissão = *@se-mov.com
# (sobrescreva se usar subdomínio de envio, ex. mail.se-mov.com, ou e-mails com prefixo distinto)
# NEXT_PUBLIC_MOV_PUBLIC_DOMAIN="se-mov.com"
# NEXT_PUBLIC_MOV_EMAIL_CONTACT="contato@se-mov.com"
# NEXT_PUBLIC_MOV_EMAIL_SUPPORT="suporte@se-mov.com"
# NEXT_PUBLIC_MOV_EMAIL_NOREPLY="noreply@se-mov.com"

# MOV Exclusivo — link completo do WhatsApp (wa.me/... ou api.whatsapp.com). Opcional; sem isto usa número de exemplo em dev.
# NEXT_PUBLIC_MOV_EXCLUSIVO_WHATSAPP="https://wa.me/5511999999999?text=Ol%C3%A1"

# MOV Essência (ex.: Tantra & Intimidade) — link completo do WhatsApp. Opcional; sem isto usa número de exemplo e texto pré-preenchido.
# NEXT_PUBLIC_MOV_ESSENCIA_WHATSAPP="https://wa.me/5511999999999?text=Ol%C3%A1"
# AUTH_URL="https://mov-staging.vercel.app"
# NEXTAUTH_URL="https://mov-staging.vercel.app"

# --- Mailtrap (sandbox SMTP) — recuperação de senha ---
# Criar inbox em https://mailtrap.io e copiar credenciais SMTP da sandbox.
MAILTRAP_HOST="sandbox.smtp.mailtrap.io"
MAILTRAP_PORT="2525"
MAILTRAP_USER="COLOCAR_USUARIO_DO_MAILTRAP_AQUI"
MAILTRAP_PASS="COLOCAR_SENHA_DO_MAILTRAP_AQUI"
# Produção: use remetente no domínio verificado, ex. "MOV <noreply@se-mov.com>"
MAIL_FROM="no-reply@mov.local"

# Recuperação de senha — alternativas (ordem no código: Resend > Mailtrap > SMTP genérico)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="MOV <onboarding@resend.dev>"
#
# SMTP genérico (se não usar Mailtrap)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""

# Seed: conta admin (npm run db:seed)
# ADMIN_SEED_EMAIL="admin@example.com"
# ADMIN_SEED_PASSWORD="..."

# Playwright E2E (admin) — definir para CI / máquina local
# E2E_ADMIN_EMAIL="..."
# E2E_ADMIN_PASSWORD="..."

# Seed: utilizador comum para testar login e área /app (role=user; não usar em produção)
# DEV_SEED_EMAIL="user@mov.local"
# DEV_SEED_PASSWORD="movdev123"

# Admin: em produção, defina 1 para permitir filtro `?includeTest=1` (mostrar contas E2E/QA na listagem)
# MOV_ADMIN_LIST_TEST_USERS="1"
